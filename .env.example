# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=opc_user
POSTGRES_PASSWORD=opc_password
POSTGRES_DB=opc_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Async URL used by SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://opc_user:opc_password@db:5432/opc_db

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OPC-UA Collector ─────────────────────────────────────────────────────────
# Injected by docker-compose; override here for local runs outside Docker
OPCUA_URL=opc.tcp://simulator:4840
POLL_INTERVAL=5
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=60.0
